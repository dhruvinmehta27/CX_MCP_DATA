# Local development only — on BTP CF these come from service bindings / cf set-env
PORT=8080
C4C_DESTINATION=C4C_QUA_OBO
DASHBOARD_APP_ORIGIN=http://localhost:5173

# Claude API (cf set-env in production, never committed)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Alternative auth for POST /api/dashboard/inline (Copilot Studio)
INLINE_API_KEY=

# Local dev: paste the destination-service binding JSON here to call C4C
# VCAP_SERVICES={"destination":[{"credentials":{"clientid":"...","clientsecret":"...","url":"https://....authentication.eu10.hana.ondemand.com","uri":"https://destination-configuration.cfapps.eu10.hana.ondemand.com"}}]}

CACHE_TTL_SECONDS=900
